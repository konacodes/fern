# Fern Environment Configuration

# Server
PORT=3000
NODE_ENV=development

# Anthropic API (required)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Twilio SMS (optional - for SMS messaging)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Webhook settings
WEBHOOK_BASE_URL=https://your-domain.com

# Database (optional - defaults to ./data/fern.db)
DATABASE_URL=./data/fern.db

# Authentication codes (comma-separated, optional)
# If set, new users must provide one of these codes to use Fern
AUTH_CODES=magic-word-1,secret-code-2

# Logging
LOG_LEVEL=info
