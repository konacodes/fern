# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Database
DATABASE_URL=./data/fern.db

# Server
PORT=3000
WEBHOOK_BASE_URL=https://your-domain.com

# Authentication
AUTH_CODES=code1,code2,code3

# Chrome MCP (optional, for browser automation)
CHROME_MCP_URL=http://localhost:3001
