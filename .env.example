# Matrix homeserver URL, e.g. http://localhost:6167
HOMESERVER_URL=http://localhost:6167

# Bot user ID on the homeserver, e.g. @fern:fern.local
BOT_USER=@fern:kcodes.me

# Password for the bot account
BOT_PASSWORD=change-me

# Local directory for Matrix SDK + SQLite data
DATA_DIR=./data

# Cerebras API key used for chat completions
CEREBRAS_API_KEY=your-cerebras-api-key

# Cerebras chat model (defaults to qwen-3-235b)
CEREBRAS_MODEL=qwen-3-235b

# Cerebras API base URL (defaults to https://api.cerebras.ai/v1)
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# SQLite database URL for conversation persistence (defaults to sqlite://{DATA_DIR}/fern.db)
DATABASE_URL=sqlite://./data/fern.db
